# Получить ключ: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your_key_here

# Папка для сохранения транскрипций
TRANSCRIPTS_DIR=./transcripts

# База данных
DB_PATH=./data/cache.db

# Модель Whisper: tiny | base | small | medium | large-v3-turbo
# На Apple Silicon (M1-M4) используется MLX GPU — medium работает быстро
# На обычном CPU рекомендуется small или base
WHISPER_MODEL=medium

# Устройство (для не-Apple: cpu; на Apple Silicon игнорируется — всегда MLX GPU)
WHISPER_DEVICE=cpu

# Параллельных транскрипций одновременно
MAX_WORKERS=2

# Максимальная длина видео (секунды). 10800 = 3 часа
MAX_VIDEO_DURATION_SEC=10800

# Размер чанка для длинных видео (минуты)
AUDIO_CHUNK_MINUTES=15

# Сервер
HOST=127.0.0.1
PORT=8000
DEBUG=false
